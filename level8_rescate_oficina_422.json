  "cinematic_events": [
    {
      "id": "cine_intro_llamada_422",
      "section_id": "s01_inicio_servicios_5f",
      "trigger": "on_level_start",
      "mode": "radio_overlay",
      "dialogue": [
        {
          "speaker": "compañera_422",
          "tone": "urgente",
          "text": "¡Estoy en la oficina 422 del cuarto piso! Estoy rodeada, necesito extracción inmediata."
        },
        {
          "speaker": "protagonista",
          "tone": "decidido",
          "text": "Recibido. Voy en camino. Mantén la puerta trabada el mayor tiempo posible."
        }
      ],
      "on_complete": [
        "activate_section:s02_reversa_sector_n7"
      ]
    },
    {
      "id": "cine_rescate_oficina_422",
      "section_id": "s05_oficina_422_rescate",
      "trigger": "on_interact_rescue_target",
      "mode": "in_world_dialog",
      "dialogue": [
        {
          "speaker": "compañera_422",
          "tone": "agotada",
          "text": "Pensé que no llegarías... escucho más golpes afuera."
        },
        {
          "speaker": "protagonista",
          "tone": "calmado",
          "text": "Nos movemos juntos. Cúbrete detrás de mí cuando empiece la oleada."
        },
        {
          "speaker": "sistema",
          "tone": "alerta",
          "text": "Múltiples contactos detectados en accesos de oficina 422."
        }
      ],
      "on_complete": [
        "start_combat_zone:cz_oficina_422_oleada_nueva"
      ]
    },
    {
      "id": "cine_hall_mensaje_hermana",
      "section_id": "s06_salida_a_hall_ascensores",
      "trigger": "on_enter_section",
      "mode": "in_world_dialog",
      "dialogue": [
        {
          "speaker": "aliada_ia",
          "tone": "preocupada",
          "text": "Me llegó un mensaje de mi hermana... está en el piso 1, barricada en una sala."
        },
        {
          "speaker": "protagonista",
          "tone": "urgente",
          "text": "Entonces bajamos ahora. Si ese grupo entra, no tendrán salida."
        },
        {
          "speaker": "sistema",
          "tone": "objetivo_actualizado",
          "text": "Checkpoint restaurado. Inicia cuenta regresiva para defensa en piso 1."
        }
      ],
      "on_complete": [
        "trigger_checkpoint:cp_restaurado_hall_ascensores",
        "start_timer:te_level8_descenso_piso1",
        "set_objective:fo_defensa_piso1"
